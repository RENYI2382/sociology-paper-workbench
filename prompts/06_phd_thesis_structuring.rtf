\uc0\u35831 \u20320 \u25198 \u28436 \u19968 \u20301 \u32463 \u39564 \u20016 \u23500 \u30340 \u21338 \u22763 \u29983 \u23548 \u24072 \u65292 \u20026 \u25105 \u25776 \u20889 \u19968 \u31687 \u21338 \u22763 \u35770 \u25991 \u30340 \u32467 \u26500 \u21270 \u25688 \u35201 \u65288 Structured Abstract\u65289 \u65292 \u22823 \u32422 400-500\u23383 \u12290 \u25105 \u30340 \u35770 \u25991 \u20027 \u39064 \u26159 [\u20320 \u30340 \u35770 \u25991 \u20027 \u39064 ]\u65292 \u37319 \u29992 \u20102 [\u20320 \u30340 \u30740 \u31350 \u26041 \u27861 ]\u65292 \u20027 \u35201 \u21457 \u29616 \u26159 [\u20320 \u30340 \u26680 \u24515 \u21457 \u29616 ]\u12290 \u35831 \u20005 \u26684 \u25353 \u29031 \u20197 \u19979 \u32467 \u26500 \u36827 \u34892 \u25776 \u20889 \u65306 \
