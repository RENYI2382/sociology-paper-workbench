### Prompt 1\uc0\u65306 \u30740 \u31350 \u26680 \u24515 \u27010 \u24565 \u30028 \u23450 \
**Prompt\uc0\u65306 **\
\uc0\u25105 \u27491 \u22312 \u25776 \u20889 \u20851 \u20110 [\u30740 \u31350 \u39046 \u22495 \u65292 \u20363 \u22914 \u65306 \u22522 \u20110 \u28145 \u24230 \u23398 \u20064 \u30340 \u38146 \u31163 \u23376 \u30005 \u27744 \u30005 \u26497 \u26448 \u26009 ]\u30340 \u21338 \u22763 \u23398 \u20301 \u35770 \u25991 \u12290 \u26680 \u24515 \u30740 \u31350 \u38382 \u39064 \u26159 [\u28165 \u26224 \u38416 \u36848 \u20320 \u30340 \u26680 \u24515 \u30740 \u31350 \u38382 \u39064 \u65292 such as\u65306 \u22914 \u20309 \u36890 \u36807 \u29616 \u26377 \u30340 \u38146 \u30005 \u27744 \u36127 \u26497 \u26448 \u26009 \u25968 \u25454 \u26469 \u25552 \u21319 \u23545 \u20855 \u26377 \u29305 \u27530 \u32467 \u26500 \u30340 \u36127 \u26497 \u26448 \u26009 \u30340 \u39044 \u27979 \u31934 \u24230 \u65311 ]\u12290 \u22522 \u20110 \u27492 \u38382 \u39064 \u65292 \u23436 \u25104 \u20197 \u19979 \u20219 \u21153 \u65306 \
1. \uc0\u26680 \u24515 \u27010 \u24565 \u30028 \u23450 \u65288 Conceptual Definition\u65289 :\u23450 \u20041 \u24182 \u38416 \u36848 \u19982 \u27492 \u30740 \u31350 \u38382 \u39064 \u30452 \u25509 \u30456 \u20851 \u30340 3-5\u20010 \u26680 \u24515 \u23398 \u26415 \u27010 \u24565 \u65292 \u20363 \u22914 \u65306 \u38146 \u31163 \u23376 \u30005 \u27744 \u65292 \u36127 \u26497 \u26448 \u26009 \u65292 \u20307 \u31215 \u33192 \u32960 \u65292 \u24490 \u29615 \u31283 \u23450 \u24615 \u65292 \u22266 \u24577 \u30005 \u35299 \u36136 \u30456 \u12290 \u38656 \u35201 \u20307 \u29616 \u20986 \u20854 \u22312 \u35813 \u30740 \u31350 \u39046 \u22495 \u20869 \u30340 \u29305 \u23450 \u20869 \u28085 \u12290 \
2. \uc0\u30740 \u31350 \u38382 \u39064 \u35299 \u26500 \u65288 Problem Decomposition\u65289 :\u23558 \u19978 \u36848 \u26680 \u24515 \u30740 \u31350 \u38382 \u39064 \u20998 \u35299 \u20026 3-4\u20010 \u21487 \u25191 \u34892 \u12289 \u21487 \u39564 \u35777 \u30340 \u23376 \u38382 \u39064 (Sub-questions)\u12290 \u27599 \u20010 \u23376 \u38382 \u39064 \u37117 \u24212 \u26356 \u20855 \u20307 \u65292 \u24182 \u20849 \u21516 \u25351 \u21521 \u23545 \u26680 \u24515 \u38382 \u39064 \u30340 \u35299 \u31572 \u12290 \
3. \uc0\u21019 \u26032 \u24615 \u22768 \u26126 \u65288 Novelty Statement\u65289 :\u22522 \u20110 \u20320 \u23545 \u35813 \u39046 \u22495 \u30340 \u29702 \u35299 \u65292 \u33609 \u25311 \u19968 \u27573 150-200\u23383 \u30340 \u21019 \u26032 \u24615 \u22768 \u26126 \u65292 \u28165 \u26224 \u22320 \u35770 \u36848 \u25105 \u30340 \u30740 \u31350 \u30456 \u36739 \u20110 \u29616 \u26377 \u25216 \u26415 \u65288 \u20363 \u22914 \u65306 AlphaFold 2\u65289 \u21487 \u33021 \u23384 \u22312 \u30340 \u29702 \u35770 \u12289 \u26041 \u27861 \u25110 \u24212 \u29992 \u23618 \u38754 \u30340 \u36129 \u29486 \u12290 \
\
