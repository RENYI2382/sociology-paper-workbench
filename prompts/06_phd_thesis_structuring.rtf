\uc0\u25105 \u30340 \u21338 \u22763 \u35770 \u25991 \u37319 \u29992 \u23450 \u24615 \u30740 \u31350 \u26041 \u27861 \u65292 \u20855 \u20307 \u20026 [\u20363 \u22914 \u65306 \u22810 \u26696 \u20363 \u30740 \u31350 \u65288 Multiple Case Study\u65289 / \u25166 \u26681 \u29702 \u35770 \u65288 Grounded Theory\u65289 ]\u12290 \u20026 \u20102 \u25552 \u21319 \u30740 \u31350 \u30340 \u20005 \u35880 \u24615 \u65292 \u25105 \u38656 \u35201 \u19987 \u38376 \u25776 \u20889 \u19968 \u33410 \u26469 \u35770 \u36848 \u22914 \u20309 \u20445 \u38556 \u26412 \u30740 \u31350 \u30340 \'93\u21487 \u20449 \u24230 \'94(Credibility)\u12289 \'93\u21487 \u36716 \u31227 \u24615 \'94(Transferability)\u12289 \'93\u21487 \u38752 \u24615 \'94(Dependability)\u21644 \'93\u21487 \u30830 \u35748 \u24615 \'94(Confirmability)\u65288 Guba & Lincoln, 1985\u65289 \u12290 \u35831 \u20026 \u25105 \u38024 \u23545 \u36825 \u22235 \u20010 \u20934 \u21017 \u65292 \u20998 \u21035 \u25552 \u20379 3-4\u31181 \u20855 \u20307 \u21487 \u25805 \u20316 \u30340 \u31574 \u30053 \u65292 \u24182 \u20026 \u27599 \u31181 \u31574 \u30053 \u25552 \u20379 \u31616 \u35201 \u35828 \u26126 \u12290 \
